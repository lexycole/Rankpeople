{
  "name": "@repo/environment",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist && rm -rf .turbo && rm tsconfig.tsbuildinfo",
    "dev": "tsc -b -w --preserveWatchOutput",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts*\" --max-warnings 0",
    "start": "node -r esbuild-register ./src/index.ts",
    "test": "jest --detectOpenHandles"
  },
  "dependencies": {
    "@repo/eslint-config": "*"
  },
  "devDependencies": {
    "@types/jest": "*",
    "semantic-release": "*",
    "semantic-release-monorepo": "*",
    "typescript": "*"
  }
}